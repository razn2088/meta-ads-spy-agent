# LLM Provider: "openai" or "gemini"
LLM_PROVIDER=openai

# API Keys (fill in the one matching your provider)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# Optional: Residential proxy URL for Meta scraping
PROXY_URL=

# WhatsApp admin group name (for error notifications)
ADMIN_WHATSAPP_GROUP=Admin Alerts

# Path to persist WhatsApp Web login session
WHATSAPP_PROFILE_DIR=./data/whatsapp_profile
